# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Wrangler local state
.wrangler

# Local env files
.env
.env.*
!.env.example

# Analytics OAuth token cache (contains refresh tokens — never commit)
.analytics-token.json

# Google service account key (if ever added)
google-service-account.json

# Outreach lead data (contains PII — never commit)
outreach/
!outreach/.gitkeep

# WhatsApp Baileys session (contains auth keys — never commit)
outreach/.wa-session/

# Local Claude/Codex skill and Playwright CLI runtime artifacts
.playwright-cli/

# Playwright test artifacts (traces, screenshots, error reports)
test-results/
playwright-report/

# Audit screenshots (ephemeral, generated during browser sessions)
screenshots/

# MCP server config (may contain local paths)
.mcp.json

# Autopilot active state (ephemeral, never commit)
autopilot/active/
